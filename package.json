{
  "name": "vitepress-docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vitepress dev docs --host 127.0.0.1 --port 5175",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs --host 127.0.0.1 --port 4175",
    "check": "tsc --noEmit -p tsconfig.json",
    "contentrain:generate": "contentrain generate",
    "deploy:netlify": "pnpm build"
  },
  "dependencies": {
    "@contentrain/query": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "contentrain": "^0.3.1",
    "typescript": "^5.9.2",
    "vitepress": "^1.6.3"
  },
  "imports": {
    "#contentrain": {
      "types": "./.contentrain/client/index.d.ts",
      "import": "./.contentrain/client/index.mjs",
      "require": "./.contentrain/client/index.cjs"
    },
    "#contentrain/*": {
      "types": "./.contentrain/client/*.d.ts",
      "import": "./.contentrain/client/*.mjs",
      "require": "./.contentrain/client/*.cjs"
    }
  }
}
